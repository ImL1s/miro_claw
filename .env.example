# LLM Configuration (required)
LLM_API_KEY=your-openai-compatible-api-key
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL_NAME=your-model-name

# Zep GraphRAG (required for MiroFish)
ZEP_API_KEY=your-zep-api-key

# MiroFish Backend
MIROFISH_URL=http://localhost:5001
MIROFISH_DIR=                              # Override MiroFish source directory for native mode (leave empty for default)

# P2P Configuration
P2P_AUTO_PREDICT=false                     # Set to "true" to auto-run predictions on received seeds

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=http://localhost:18787 # Gateway URL for push notifications

# Discord Notifications
MIROFISH_DISCORD_WEBHOOK=                  # Discord webhook URL for run notifications (optional)

# Distributed Mode (oasis-distributed)
MIROFISH_CLUSTER_TOKEN=                    # Pre-shared token for gRPC auth between Coordinator and Workers
COORDINATOR_ADDR=localhost:50051           # Coordinator gRPC address (used by Workers)
